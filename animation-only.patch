diff --git a/public/collections.html b/public/collections.html
index 86590c4..e433c4d 100644
--- a/public/collections.html
+++ b/public/collections.html
@@ -52,8 +52,13 @@ img { display: block; max-width: 100%; }
 
 /* --- COLLECTION SWATCH --- */
 .coll-swatch { width: 100%; height: 715px; overflow: hidden; position: relative; }
-.coll-swatch-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.8s ease; }
-.coll-swatch-img.active { opacity: 1; }
+.coll-swatch-img { position: absolute; inset: 0; width: 110%; height: 110%; object-fit: cover; opacity: 0; transition: opacity 0.8s ease; transform: translate(0, 0); }
+.coll-swatch-img.active { opacity: 1; animation: slabPan 25s ease-in-out infinite alternate; }
+@keyframes slabPan {
+  0% { transform: translate(0, 0) scale(1); }
+  50% { transform: translate(-3%, -2%) scale(1.02); }
+  100% { transform: translate(-5%, -1%) scale(1); }
+}
 .coll-swatch-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 32px 40px; background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 100%); pointer-events: none; z-index: 1; }
 .coll-swatch-label { font-family: 'Concrette S', serif; font-weight: 400; font-size: 14px; color: var(--white); line-height: 1.4; }
 
@@ -108,6 +113,11 @@ img { display: block; max-width: 100%; }
 .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
 .reveal.visible { opacity: 1; transform: translateY(0); }
 
+/* --- REDUCED MOTION --- */
+@media (prefers-reduced-motion: reduce) {
+  .coll-swatch-img.active { animation: none !important; width: 100%; height: 100%; }
+}
+
 /* --- MOBILE --- */
 @media (max-width: 1024px) {
   .hero { height: 400px; }
